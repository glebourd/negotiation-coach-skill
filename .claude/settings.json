{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "WebFetch",
      "WebSearch"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if [ ! -f CLAUDE.md ]; then cp SKILL.md CLAUDE.md && echo 'Negotiation Coach activated. Type kickoff to start.'; fi"
          }
        ]
      }
    ]
  }
}
